{
  "name": "printflow",
  "version": "1.0.0",
  "description": "QR Based Cloud Printing Platform",
  "main": "server.js",
  "author": "PrintFlow",
  "license": "MIT",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "electron": "electron electron/main.js",
    "dist": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-is-dev": "^3.0.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "firebase": "^10.12.2",
    "firebase-admin": "^12.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pdf-parse": "^1.1.1",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.4",
    "uuid": "^10.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3",
    "icon-gen": "^5.0.0",
    "nodemon": "^3.1.4"
  },
  "build": {

  "appId": "com.pixelelevenlabs.printflow",

  "productName": "PrintFlow",

  "directories": {

    "output": "dist"

  },

  "files": [

    "electron/**/*",

    "*.js",

    ".env",

    "package.json"

  ],

  "mac": {

    "target": "dmg",

    "icon": "electron/assets/icon.icns",

    "category": "public.app-category.productivity"

  },

  "win": {

  "target": "nsis"

},

  "linux": {

    "target": "AppImage"

  }
}
}